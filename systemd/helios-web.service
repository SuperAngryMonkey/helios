[Unit]
Description=Helios — web dashboard
Documentation=https://github.com/SuperAngryMonkey/helios
After=helios.service postgresql.service network-online.target
Wants=helios.service
Requires=postgresql.service

[Service]
Type=simple
User=helios
Group=helios
WorkingDirectory=/opt/helios/web
ExecStart=/opt/helios/bin/gunicorn --workers 2 --bind 0.0.0.0:5000 --access-logfile - --error-logfile - app:app
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=helios-web

# Hardening — no privilege escalation is possible or needed.
# The admin form writes /etc/helios/controller.env directly (mode 660,
# root:helios). The helios-config.path unit watches for changes and
# triggers helios-restart.service, which does the actual daemon restart.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/helios /etc/helios/controller.env
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=true

[Install]
WantedBy=multi-user.target
